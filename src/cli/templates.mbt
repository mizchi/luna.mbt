// Sol CLI Templates - Embedded template files for project scaffolding
//

///|
fn template_gitignore() -> String {
  (
    #|.mooncakes
    #|_build
    #|target
    #|node_modules
    #|# Generated by sol generate (types/ is kept for initial build)
    #|app/__gen__/client
    #|app/__gen__/server
    #|.sol
  )
}

///|
fn template_moon_mod_json(package_name : String, luna_path : String?) -> String {
  match luna_path {
    Some(path) => {
      // Development mode - use local path
      let tmpl =
        #|{
        #|  "name": "{{PACKAGE_NAME}}",
        #|  "version": "0.1.0",
        #|  "deps": {
        #|    "mizchi/sol": "0.8.0",
        #|    "mizchi/mars": "0.3.9",
        #|    "mizchi/luna": {
        #|      "path": "{{LUNA_PATH}}"
        #|    },
        #|    "mizchi/signals": "0.6.3",
        #|    "mizchi/js": "0.10.14",
        #|    "mizchi/npm_typed": "0.1.11"
        #|  },
        #|  "source": "app",
        #|  "preferred-target": "js"
        #|}
      tmpl
      .replace(old="{{PACKAGE_NAME}}", new=package_name)
      .replace(old="{{LUNA_PATH}}", new=path)
    }
    None => {
      // Production mode - use mooncakes version
      let tmpl =
        #|{
        #|  "name": "{{PACKAGE_NAME}}",
        #|  "version": "0.1.0",
        #|  "deps": {
        #|    "mizchi/sol": "0.10.0",
        #|    "mizchi/mars": "0.3.9",
        #|    "mizchi/luna": "0.16.0",
        #|    "mizchi/signals": "0.6.3",
        #|    "mizchi/js": "0.10.14",
        #|    "mizchi/npm_typed": "0.1.11"
        #|  },
        #|  "source": "app",
        #|  "preferred-target": "js"
        #|}
      tmpl.replace(old="{{PACKAGE_NAME}}", new=package_name)
    }
  }
}

///|
fn template_package_json(project_name : String) -> String {
  let tmpl =
    #|{
    #|  "name": "{{PROJECT_NAME}}",
    #|  "version": "0.1.0",
    #|  "type": "module",
    #|  "scripts": {
    #|    "dev": "sol dev",
    #|    "build": "sol build",
    #|    "serve": "sol serve",
    #|    "generate": "sol generate"
    #|  },
    #|  "dependencies": {
    #|    "hono": "^4.0.0",
    #|    "@hono/node-server": "^1.0.0"
    #|  },
    #|  "devDependencies": {
    #|    "rolldown": "^1.0.0-beta.54"
    #|  }
    #|}
  tmpl.replace(old="{{PROJECT_NAME}}", new=project_name)
}

///|
fn template_sol_config_json() -> String {
  (
    #|{
    #|  "islands": ["app/client"],
    #|  "routes": "app/server",
    #|  "output": "app/__gen__",
    #|  "runtime": "node"
    #|}
  )
}

// Note: For different runtimes, update sol.config.json:
// - "node"       - Node.js with @hono/node-server (default)
// - "cloudflare" - Cloudflare Workers (exports fetch handler)
// - "deno"       - Deno.serve
// - "bun"        - Bun.serve

// ============================================================================
// New Architecture Templates (routes-based)
// ============================================================================

///|
/// Layout template - provides basic HTML structure
/// Users explicitly call layout([...inner]) in their pages
pub fn template_layout_mbt() -> String {
  (
    #|///| Server Layout Component
    #|///|
    #|///| Provides the basic HTML structure for all pages.
    #|///| This is a server component - no event handlers.
    #|
    #|///| Default page styles
    #|let default_style : String = "<style>body { font-family: system-ui; max-width: 800px; margin: 0 auto; padding: 2rem; } .counter { margin: 2rem 0; padding: 1rem; border: 1px solid #ccc; border-radius: 8px; } .buttons { margin-top: 1rem; } .buttons button { font-size: 1.5rem; padding: 0.5rem 1rem; margin: 0 0.5rem; cursor: pointer; } nav { margin-bottom: 1rem; } nav a { margin-right: 1rem; }</style>"
    #|
    #|///| Get default head HTML (styles)
    #|pub fn head() -> String {
    #|  default_style
    #|}
    #|
    #|///| Basic layout wrapper - wraps content in container with navigation
    #|pub fn layout(inner : Array[@luna.Node[Unit, String]]) -> @luna.Node[Unit, String] {
    #|  div(class="container", [
    #|    nav([
    #|      a(href="/", [text("Home")]),
    #|      a(href="/about", [text("About")]),
    #|    ]),
    #|    outlet(name="main", inner),
    #|  ])
    #|}
    #|
    #|///| Root layout function for SolRoutes::Layout
    #|pub fn root_layout(
    #|  _props : @router.PageProps,
    #|  content : @server_dom.ServerNode,
    #|) -> @server_dom.ServerNode raise Error {
    #|  @server_dom.ServerNode::async_(async fn() {
    #|    let inner = content.resolve()
    #|    layout([inner])
    #|  })
    #|}
  )
}

///|
/// Layout moon.pkg
pub fn template_layout_moon_pkg() -> String {
  (
    #|import {
    #|  "mizchi/luna" @luna,
    #|  "mizchi/sol/router" @router,
    #|  "mizchi/luna/dom/static" @server_dom,
    #|}
    #|
    #|options(
    #|  "supported-targets": [ "js" ],
    #|  "warn-list": "-24",
    #|)
  )
}

///|
/// Server _using.mbt template - DSL imports for server components
pub fn template_server_using_mbt() -> String {
  (
    #|///| Server-side element DSL imports
    #|using @server_dom {
    #|  div,
    #|  a,
    #|  nav,
    #|  text,
    #|  outlet,
    #|}
  )
}

///|
/// Routes template - single source of truth for all routes
pub fn template_routes_mbt(package_name : String) -> String {
  let tmpl =
    #|///| Route Definitions
    #|///|
    #|///| This is the single source of truth for all routes.
    #|///|
    #|/// IMPORTANT: This is a magic file - sol generate reads this to:
    #|/// - Generate server entry point
    #|/// - Generate client hydration router
    #|/// - Setup route handlers
    #|
    #|/// Application routes - defines all pages and API endpoints
    #|pub fn routes() -> Array[@router.SolRoutes] {
    #|  [
    #|    @router.SolRoutes::Layout(segment="", layout=@layout.root_layout, children=[
    #|      // Home page with counter island
    #|      @router.SolRoutes::Page(
    #|        path="/",
    #|        handler=@router.PageHandler(home),
    #|        title="Home",
    #|        meta=[],
    #|        revalidate=None,
    #|        cache=None,
    #|      ),
    #|      // About page (static, no hydration)
    #|      @router.SolRoutes::Page(
    #|        path="/about",
    #|        handler=@router.PageHandler(about),
    #|        title="About",
    #|        meta=[],
    #|        revalidate=None,
    #|        cache=None,
    #|      ),
    #|    ]),
    #|    // API endpoint
    #|    @router.SolRoutes::Get(
    #|      path="/api/health",
    #|      handler=@router.ApiHandler(api_health),
    #|    ),
    #|  ]
    #|}
    #|
    #|///| Router configuration
    #|pub fn config() -> @router.RouterConfig {
    #|  @router.RouterConfig::default()
    #|    .with_default_head(@layout.head())
    #|    .with_loader_url("/__sol__/loader.js")
    #|}
    #|
    #|///| Server Action registry (empty by default)
    #|pub fn action_registry() -> @action.ActionRegistry {
    #|  @action.ActionRegistry::new()
    #|}
    #|
    #|// ============================================================================
    #|// Page Definitions (inline in routes.mbt)
    #|// ============================================================================
    #|
    #|///| Home page - with counter island
    #|async fn home(_props : @router.PageProps) -> @server_dom.ServerNode {
    #|  let counter_props : @types.CounterProps = { initial_count: 0 }
    #|  let content = [
    #|    h1([text("Welcome to Sol")]),
    #|    p([text("A SSR-first web framework for MoonBit")]),
    #|    @server_dom.client(@types.counter(counter_props), [
    #|      div(class="counter", [
    #|        span(class="count-display", [
    #|          text(counter_props.initial_count.to_string()),
    #|        ]),
    #|        div(class="buttons", [
    #|          button(class="dec", [text("-")]),
    #|          button(class="inc", [text("+")]),
    #|        ]),
    #|      ]),
    #|    ]),
    #|  ]
    #|  @server_dom.ServerNode::sync(@luna.fragment(content))
    #|}
    #|
    #|///| About page - static
    #|async fn about(_props : @router.PageProps) -> @server_dom.ServerNode {
    #|  let content = [
    #|    h1([text("About")]),
    #|    p([text("Built with MoonBit and Sol framework.")]),
    #|  ]
    #|  @server_dom.ServerNode::sync(@luna.fragment(content))
    #|}
    #|
    #|///| API handler: health check
    #|async fn api_health(_props : @router.PageProps) -> @core.Any {
    #|  @sol.json_obj([("status", @core.any("ok"))])
    #|}
  tmpl.replace_all(old="{{PACKAGE_NAME}}", new=package_name)
}

///|
/// Routes moon.pkg
pub fn template_routes_moon_pkg(package_name : String) -> String {
  let tmpl =
    #|import {
    #|  "mizchi/luna" @luna,
    #|  "mizchi/sol" @sol,
    #|  "mizchi/sol/router" @router,
    #|  "mizchi/sol/action" @action,
    #|  "mizchi/luna/dom/static" @server_dom,
    #|  "mizchi/js/core" @core,
    #|  "{{PACKAGE_NAME}}/layout" @layout,
    #|  "{{PACKAGE_NAME}}/__gen__/types" @types,
    #|}
    #|
    #|options(
    #|  "supported-targets": [ "js" ],
    #|  "warn-list": "-67",
    #|)
  tmpl.replace_all(old="{{PACKAGE_NAME}}", new=package_name)
}

///|
/// Routes _using.mbt template - DSL imports for routes package
pub fn template_routes_using_mbt() -> String {
  (
    #|///| Server-side element DSL imports
    #|using @server_dom {
    #|  div,
    #|  span,
    #|  button,
    #|  h1,
    #|  p,
    #|  text,
    #|}
  )
}

///|
/// Client island template (counter example)
pub fn template_client_counter_mbt() -> String {
  (
    #|// Counter Client Component
    #|// Client components receive Props and return DomNode.
    #|
    #|///|
    #|/// Hydration functions are auto-generated by `sol generate`.
    #|using @element {
    #|  type DomNode,
    #|  div,
    #|  span,
    #|  button,
    #|  text,
    #|  text_of,
    #|  events,
    #|}
    #|
    #|///|
    #|/// Props passed from server
    #|pub(all) struct CounterProps {
    #|  initial_count : Int
    #|} derive(ToJson, FromJson)
    #|
    #|///|
    #|/// Counter component
    #|pub fn counter(props : CounterProps) -> DomNode {
    #|  let count = @signal.signal(props.initial_count)
    #|  div(class="counter", [
    #|    span(class="count-display", [text_of(count)]),
    #|    div(class="buttons", [
    #|      button(class="dec", on=events().click(_ => count.update(n => n - 1)), [
    #|        text("-"),
    #|      ]),
    #|      button(class="inc", on=events().click(_ => count.update(n => n + 1)), [
    #|        text("+"),
    #|      ]),
    #|    ]),
    #|  ])
    #|}
  )
}

///|
/// Client counter moon.pkg
pub fn template_client_counter_moon_pkg() -> String {
  (
    #|import {
    #|  "moonbitlang/core/json",
    #|  "mizchi/luna/dom" @element,
    #|  "mizchi/signals" @signal,
    #|}
    #|
    #|options(
    #|  "supported-targets": [ "js" ],
    #|  link: { "js": { "exports": [ "counter" ], "format": "esm" } },
    #|)
  )
}

///|
pub fn template_ln_loader_js() -> String {
  @assets.get_island_loader_js()
}

///|
/// Template for __gen__/types/moon.pkg
pub fn template_gen_types_moon_pkg() -> String {
  (
    #|import {
    #|  "moonbitlang/core/json",
    #|  "mizchi/luna" @luna,
    #|}
    #|
    #|options(
