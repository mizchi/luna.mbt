// Server Generator - Generate server-side MoonBit and JS code

// =============================================================================
// MoonBit Server Generation
// =============================================================================

///|
/// Generate server main.mbt
fn generate_server_main_mbt(
  routes_pkg : String,
  route_info : RouteInfo,
  static_dirs : Array[StaticDirEntry],
) -> String {
  let _ = routes_pkg
  let _ = route_info
  let buf = StringBuilder::new()
  buf.write_string("///| Auto-generated server entry point\n")
  buf.write_string("///| Generated by: sol generate\n")
  buf.write_string("///|\n")
  buf.write_string(
    "///| DO NOT EDIT - This file is auto-generated from server/routes.mbt\n\n",
  )
  buf.write_string("///| Configure the application using typed routes\n")
  buf.write_string("pub fn configure_app() -> @sol.App {\n")
  buf.write_string("  // Create a new Server app\n")
  buf.write_string("  let app = @sol.create_app()\n\n")
  buf.write_string("  // Get routes and config from server/routes.mbt\n")
  buf.write_string("  let routes = @app_server.routes()\n")
  buf.write_string("  let config = @app_server.config()\n\n")
  buf.write_string(
    "  // Register routes with typed handlers (no resolver needed)\n",
  )
  buf.write_string("  @router.register_sol_routes(app, routes, config=config)\n\n")
  buf.write_string(
    "  // Register Server Actions (if action_registry is defined in routes.mbt)\n",
  )
  buf.write_string("  @action.register_actions(app, @app_server.action_registry())\n\n")

  // Generate static directory routes
  if not(static_dirs.is_empty()) {
    buf.write_string("  // Serve static directories (SSG)\n")
    for entry in static_dirs {
      let path_prefix = entry.path_prefix
      let source_dir = entry.source_dir
      buf.write_string(
        "  @sol.serve_static_dir(app, @sol.StaticDirServeConfig::new(\"\{path_prefix}\", \"\{source_dir}\"))\n",
      )
    }
    buf.write_string("\n")
  }
  buf.write_string("  // Serve static files\n")
  buf.write_string("  @sol.serve_static(app)\n\n")
  buf.write_string("  app\n")
  buf.write_string("}\n\n")
  buf.write_string("///|\n")
  buf.write_string("fn main {\n")
  buf.write_string("  @sol.run_app(configure_app)\n")
  buf.write_string("}\n")
  buf.to_string()
}

///|
/// Generate server moon.pkg.json
fn generate_server_pkg_json(routes_pkg : String) -> String {
  let buf = StringBuilder::new()
  buf.write_string("{\n")
  buf.write_string("  \"supported-targets\": [\"js\"],\n")
  buf.write_string("  \"is-main\": true,\n")
  buf.write_string("  \"import\": [\n")
  buf.write_string("    { \"path\": \"mizchi/sol\", \"alias\": \"sol\" },\n")
  buf.write_string(
    "    { \"path\": \"mizchi/sol/router\", \"alias\": \"router\" },\n",
  )
  buf.write_string(
    "    { \"path\": \"mizchi/sol/action\", \"alias\": \"action\" },\n",
  )
  buf.write_string(
    "    { \"path\": \"mizchi/js/core\", \"alias\": \"core\" },\n",
  )
  buf.write_string(
    "    { \"path\": \"\{routes_pkg}\", \"alias\": \"app_server\" }\n",
  )
  buf.write_string("  ],\n")
  buf.write_string("  \"link\": {\n")
  buf.write_string("    \"js\": {\n")
  buf.write_string("      \"exports\": [\"configure_app\"],\n")
  buf.write_string("      \"format\": \"esm\"\n")
  buf.write_string("    }\n")
  buf.write_string("  },\n")
  buf.write_string("  \"warn-list\": \"-29\"\n")
  buf.write_string("}\n")
  buf.to_string()
}

// =============================================================================
// JS Server Entry Generation
// =============================================================================

///|
/// Generate .sol/{mode}/server/main.js entry point (MoonBit mode)
/// Path: .sol/{mode}/server/main.js -> ../../../target/js/release/build/__gen__/server/server.js
pub fn generate_sol_server_main_js(
  routes_pkg : String,
  runtime : ServerRuntime,
) -> String {
  let _ = routes_pkg
  let buf = StringBuilder::new()
  buf.write_string("// Server entry point (MoonBit mode)\n")
  buf.write_string("// Generated by: sol generate\n")
  buf.write_string("// Runtime: \{runtime}\n\n")
  // Generate runtime-specific entry point
  match runtime {
    RuntimeNode => {
      buf.write_string(
        "import * as server from '../../../target/js/release/build/__gen__/server/server.js';\n\n",
      )
      buf.write_string("// Node.js runtime using @hono/node-server\n")
      buf.write_string(
        "// The server module already handles startup via @sol.run()\n",
      )
      buf.write_string(
        "export * from '../../../target/js/release/build/__gen__/server/server.js';\n",
      )
    }
    RuntimeCloudflare => {
      // Cloudflare Workers: Import module (triggers run_app which sets __SOL_APP__)
      buf.write_string(
        "// Import module to trigger run_app() which sets globalThis.__SOL_APP__\n",
      )
      buf.write_string(
        "import '../../../_build/js/release/build/__gen__/server/server.js';\n\n",
      )
      buf.write_string("// Cloudflare Workers runtime\n")
      buf.write_string(
        "// For Node.js adapter, wait for async fs init to complete\n",
      )
      buf.write_string(
        "// For edge runtimes (Cloudflare/Deno), __SOL_APP__ is set synchronously\n",
      )
      buf.write_string("const app = await new Promise(resolve => {\n")
      buf.write_string("  if (globalThis.__SOL_APP__) return resolve(globalThis.__SOL_APP__);\n")
      buf.write_string("  const check = setInterval(() => {\n")
      buf.write_string("    if (globalThis.__SOL_APP__) {\n")
      buf.write_string("      clearInterval(check);\n")
      buf.write_string("      resolve(globalThis.__SOL_APP__);\n")
      buf.write_string("    }\n")
      buf.write_string("  }, 1);\n")
      buf.write_string("});\n\n")
      buf.write_string("export default app;\n")
    }
    RuntimeDeno => {
      buf.write_string(
        "// Import module to trigger run_app() which sets globalThis.__SOL_APP__\n",
      )
      buf.write_string(
        "import '../../../_build/js/release/build/__gen__/server/server.js';\n\n",
      )
      buf.write_string("// Deno runtime\n")
      buf.write_string("const app = globalThis.__SOL_APP__;\n")
      buf.write_string(
        "const port = parseInt(Deno.env.get('PORT') || '7777', 10);\n",
      )
      buf.write_string(
        "console.log(`Server running at http://localhost:${port}`);\n",
      )
      buf.write_string("Deno.serve({ port }, app.fetch);\n")
    }
    RuntimeBun => {
      buf.write_string(
        "// Import module to trigger run_app() which sets globalThis.__SOL_APP__\n",
      )
      buf.write_string(
        "import '../../../_build/js/release/build/__gen__/server/server.js';\n\n",
      )
      buf.write_string("// Bun runtime\n")
      buf.write_string("const app = globalThis.__SOL_APP__;\n")
      buf.write_string(
        "const port = parseInt(process.env.PORT || '7777', 10);\n",
      )
      buf.write_string(
        "console.log(`Server running at http://localhost:${port}`);\n",
      )
      buf.write_string("export default {\n")
      buf.write_string("  port,\n")
      buf.write_string("  fetch: app.fetch\n")
      buf.write_string("};\n")
    }
  }
  buf.to_string()
}

///|
/// Generate .sol/{mode}/server/main.js entry point (Hybrid mode - TypeScript server)
/// Path: .sol/{mode}/server/main.js -> imports from user's routes.ts
pub fn generate_sol_server_main_js_hybrid(
  routes_dir : String,
  runtime : ServerRuntime,
) -> String {
  let buf = StringBuilder::new()
  buf.write_string("// Server entry point (Hybrid mode - TypeScript server)\n")
  buf.write_string("// Generated by: sol generate\n")
  buf.write_string("// Runtime: \{runtime}\n")
  buf.write_string("// Run with: npx tsx .sol/prod/server/main.js\n\n")

  // Note: routes_dir is relative to cwd (e.g., "app/server")
  // The generated file is at .sol/{mode}/server/main.js
  // So we need ../../../ to get back to cwd for routes.ts
  // For js/sol/ we need to go further up to repo root
  // This assumes the project is inside the sol.mbt repo (e.g., examples/sol_app)
  // TODO: Make this configurable or use npm package @sol/core
  buf.write_string("import { Hono } from 'hono';\n")
  buf.write_string(
    "import { registerRoutes } from '../../../../../js/sol/server-runtime.ts';\n",
  )
  buf.write_string(
    "import { routes, config } from '../../../\{routes_dir}/routes.ts';\n\n",
  )

  // Generate runtime-specific entry point
  match runtime {
    RuntimeNode => {
      buf.write_string("import { serve } from '@hono/node-server';\n\n")
      buf.write_string("// Node.js runtime with TypeScript routes\n")
      buf.write_string(
        "const app = registerRoutes(new Hono(), routes(), config?.() || {});\n\n",
      )
      buf.write_string(
        "const port = parseInt(process.env.PORT || '7777', 10);\n",
      )
      buf.write_string(
        "console.log(`Server running at http://localhost:${port}`);\n",
      )
      buf.write_string("serve({ fetch: app.fetch, port });\n")
    }
    RuntimeCloudflare => {
      buf.write_string("// Cloudflare Workers runtime with TypeScript routes\n")
      buf.write_string(
        "const app = registerRoutes(new Hono(), routes(), config?.() || {});\n\n",
      )
      buf.write_string("export default app;\n")
    }
    RuntimeDeno => {
      buf.write_string("// Deno runtime with TypeScript routes\n")
      buf.write_string(
        "const app = registerRoutes(new Hono(), routes(), config?.() || {});\n",
      )
      buf.write_string(
        "const port = parseInt(Deno.env.get('PORT') || '7777', 10);\n",
      )
      buf.write_string(
        "console.log(`Server running at http://localhost:${port}`);\n",
      )
      buf.write_string("Deno.serve({ port }, app.fetch);\n")
    }
    RuntimeBun => {
      buf.write_string("// Bun runtime with TypeScript routes\n")
      buf.write_string(
        "const app = registerRoutes(new Hono(), routes(), config?.() || {});\n",
      )
      buf.write_string(
        "const port = parseInt(process.env.PORT || '7777', 10);\n",
      )
      buf.write_string(
        "console.log(`Server running at http://localhost:${port}`);\n",
      )
      buf.write_string("export default {\n")
      buf.write_string("  port,\n")
      buf.write_string("  fetch: app.fetch\n")
      buf.write_string("};\n")
    }
  }
  buf.to_string()
}

///|
/// Generate .sol/{mode}/server/serve.js - adapter wrapper for local serving
/// This imports main.js and wraps it with the specified adapter
/// Uses dynamic import to ensure SOL_ADAPTER is set before module evaluation
pub fn generate_sol_serve_js(adapter : ServerRuntime) -> String {
  let buf = StringBuilder::new()
  buf.write_string("// Server adapter for local serving\n")
  buf.write_string("// Generated by: sol generate\n")
  buf.write_string("// Adapter: \{adapter}\n")
  buf.write_string("// This file imports main.js and serves it with the adapter\n\n")
  buf.write_string("// Set adapter mode BEFORE importing main.js\n")
  buf.write_string("// (static imports are hoisted, so we use dynamic import)\n")
  buf.write_string("process.env.SOL_ADAPTER = '1';\n\n")
  buf.write_string(
    "const app = await import('./main.js').then(m => m.default);\n\n",
  )
  match adapter {
    RuntimeNode => {
      buf.write_string("const { serve } = await import('@hono/node-server');\n\n")
      buf.write_string(
        "const port = parseInt(process.env.PORT || '7777', 10);\n",
      )
      buf.write_string(
        "console.log(`Server running at http://localhost:${port}`);\n",
      )
      buf.write_string("serve({ fetch: app.fetch, port });\n")
    }
    RuntimeDeno => {
      buf.write_string(
        "const port = parseInt(Deno.env.get('PORT') || '7777', 10);\n",
      )
      buf.write_string(
        "console.log(`Server running at http://localhost:${port}`);\n",
      )
      buf.write_string("Deno.serve({ port }, app.fetch);\n")
    }
    RuntimeBun => {
      buf.write_string(
        "const port = parseInt(process.env.PORT || '7777', 10);\n",
      )
      buf.write_string(
        "console.log(`Server running at http://localhost:${port}`);\n",
      )
      buf.write_string("export default {\n")
      buf.write_string("  port,\n")
      buf.write_string("  fetch: app.fetch\n")
      buf.write_string("};\n")
    }
    RuntimeCloudflare => {
      // Cloudflare can't be used as local adapter directly, fallback to Node
      buf.write_string(
        "// Warning: Cloudflare adapter not suitable for local serving\n",
      )
      buf.write_string("// Using Node.js adapter instead\n")
      buf.write_string("const { serve } = await import('@hono/node-server');\n\n")
      buf.write_string(
        "const port = parseInt(process.env.PORT || '7777', 10);\n",
      )
      buf.write_string(
        "console.log(`Server running at http://localhost:${port}`);\n",
      )
      buf.write_string("serve({ fetch: app.fetch, port });\n")
    }
  }
  buf.to_string()
}
