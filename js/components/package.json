{
  "name": "@luna_ui/components",
  "version": "0.22.0",
  "description": "Headless UI components matching src/components APG patterns",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./core": {
      "types": "./dist/core.d.mts",
      "import": "./dist/core.mjs"
    },
    "./accordion": {
      "types": "./dist/accordion.d.mts",
      "import": "./dist/accordion.mjs"
    },
    "./checkbox": {
      "types": "./dist/checkbox.d.mts",
      "import": "./dist/checkbox.mjs"
    },
    "./switch": {
      "types": "./dist/switch.d.mts",
      "import": "./dist/switch.mjs"
    },
    "./dialog": {
      "types": "./dist/dialog.d.mts",
      "import": "./dist/dialog.mjs"
    },
    "./tabs": {
      "types": "./dist/tabs.d.mts",
      "import": "./dist/tabs.mjs"
    },
    "./slider": {
      "types": "./dist/slider.d.mts",
      "import": "./dist/slider.mjs"
    },
    "./radio": {
      "types": "./dist/radio.d.mts",
      "import": "./dist/radio.mjs"
    },
    "./tooltip": {
      "types": "./dist/tooltip.d.mts",
      "import": "./dist/tooltip.mjs"
    },
    "./hydrate": {
      "types": "./dist/hydrate.d.mts",
      "import": "./dist/hydrate.mjs"
    },
    "./accordion-demo": {
      "types": "./dist/accordion-demo.d.mts",
      "import": "./dist/accordion-demo.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/*.ts --format esm --dts --clean",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "jsdom": "^28.1.0",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "headless",
    "ui",
    "components",
    "accessibility",
    "a11y",
    "aria",
    "apg"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizchi/luna.mbt.git",
    "directory": "js/components"
  },
  "publishConfig": {
    "access": "public"
  }
}
