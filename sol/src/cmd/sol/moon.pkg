// Sol CLI process entry point — installable via
// `moon install mizchi/sol/cmd/sol` ($MOON_HOME/bin/sol).
// Stays a thin dispatcher; all command logic lives in `mizchi/sol/cli`.

import {
  "mizchi/sol/cli" @cli,
  "mizchi/x/sys" @sys,
  "moonbitlang/async",
}

options(
  "is-main": true,
  "supported-targets": "js",
)
