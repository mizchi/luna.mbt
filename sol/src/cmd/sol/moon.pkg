// Sol CLI install entry point — installable via
// `moon install mizchi/sol/cmd/sol` ($MOON_HOME/bin/sol).
// Keep this native-compatible because `moon install` builds native binaries.

import {
  "mizchi/x/fs" @fs,
  "mizchi/x/sys" @sys,
  "mizchi/x/process" @process,
  "moonbitlang/async",
}

options(
  "is-main": true,
)

supported_targets = "native"
