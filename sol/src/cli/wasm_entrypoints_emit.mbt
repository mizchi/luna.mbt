// Wasm Entrypoints Manifest Emitters

///|
/// Generate `.sol/wasm/manifest.json`.
pub fn generate_wasm_manifest_json(entries : Array[WasmMountEntry]) -> String {
  let buf = StringBuilder::new()
  buf.write_string("{\n  \"entries\": [")
  for i, entry in entries {
    if i > 0 {
      buf.write_string(",")
    }
    buf.write_string("\n    {\n")
    buf.write_string("      \"id\": \"\{escape_json(entry.id)}\",\n")
    buf.write_string("      \"route\": \"\{escape_json(entry.route)}\",\n")
    buf.write_string("      \"method\": \{json_string_array(entry.methods)},\n")
    buf.write_string(
      "      \"runtime\": \"\{wasm_entrypoint_runtime_to_string(entry.runtime)}\",\n",
    )
    buf.write_string(
      "      \"build\": \"\{wasm_build_kind_to_string(entry.build)}\",\n",
    )
    buf.write_string("      \"wasm\": \"\{escape_json(entry.wasm)}\",\n")
    buf.write_string("      \"env\": \{json_string_map(entry.env)}\n")
    buf.write_string("    }")
  }
  if !entries.is_empty() {
    buf.write_string("\n  ")
  }
  buf.write_string("]\n}\n")
  buf.to_string()
}

///|
/// Generate env map artifact for wasm runtime host integration.
pub fn generate_wasm_env_json(entries : Array[WasmMountEntry]) -> String {
  let buf = StringBuilder::new()
  buf.write_string("{\n  \"entries\": [")
  for i, entry in entries {
    if i > 0 {
      buf.write_string(",")
    }
    buf.write_string("\n    {\n")
    buf.write_string("      \"id\": \"\{escape_json(entry.id)}\",\n")
    buf.write_string(
      "      \"runtime\": \"\{wasm_entrypoint_runtime_to_string(entry.runtime)}\",\n",
    )
    buf.write_string("      \"env\": \{json_string_map(entry.env)}\n")
    buf.write_string("    }")
  }
  if !entries.is_empty() {
    buf.write_string("\n  ")
  }
  buf.write_string("]\n}\n")
  buf.to_string()
}

///|
/// Generate Spin TOML fragment for route -> wasm mounts.
pub fn generate_spin_toml_fragment(entries : Array[WasmMountEntry]) -> String {
  let buf = StringBuilder::new()
  buf.write_string("# Auto-generated by sol build --wasm-entrypoints\n")
  buf.write_string("# Merge this fragment into your spin.toml\n\n")
  for entry in entries {
    buf.write_string("[[trigger.http]]\n")
    buf.write_string("route = \"\{escape_toml(entry.route)}\"\n")
    if entry.methods.length() == 1 {
      buf.write_string("method = \"\{escape_toml(entry.methods[0])}\"\n")
    } else if entry.methods.length() > 1 {
      buf.write_string("methods = \{toml_string_array(entry.methods)}\n")
    }
    buf.write_string("component = \"\{escape_toml(entry.id)}\"\n\n")
    buf.write_string("[component.\{entry.id}]\n")
    buf.write_string("source = \"\{escape_toml(entry.wasm)}\"\n")
    if entry.runtime == Wagi {
      buf.write_string("executor = \"wagi\"\n")
    }
    if !entry.env.is_empty() {
      buf.write_string("\n")
      buf.write_string("[component.\{entry.id}.environment]\n")
      for item in entry.env {
        buf.write_string(
          "\{escape_toml(item.0)} = \"\{escape_toml(item.1)}\"\n",
        )
      }
    }
    buf.write_string("\n")
  }
  buf.to_string()
}

///|
/// Generate mars adapter hints using upstream mars adapter APIs.
pub fn generate_mars_adapter_hints(entries : Array[WasmMountEntry]) -> String {
  let buf = StringBuilder::new()
  buf.write_string("# Auto-generated by sol build --wasm-entrypoints\n")
  buf.write_string("# mars adapter hints\n\n")
  for entry in entries {
    match entry.runtime {
      Wagi => {
        buf.write_string("# spin_wagi: \{entry.id}\n")
        buf.write_string(mars_spin_wagi_manifest_hint(entry))
        buf.write_string("\n\n")
      }
      Component => {
        buf.write_string("# wasm_component: \{entry.id}\n")
        buf.write_string(mars_wasm_component_binding_hint(entry))
        buf.write_string("\n\n")
      }
      WasiCli => ()
    }
  }
  buf.to_string()
}

///|
fn mars_spin_wagi_manifest_hint(entry : WasmMountEntry) -> String {
  let config : @mars_adapters.SpinWagiConfig = {
    component: entry.id,
    route: entry.route,
    executor: "wagi",
  }
  let adapter = @mars_adapters.spin_wagi_adapter(@mars.Server::new(), config~)
  adapter.manifest_hint()
}

///|
fn mars_wasm_component_binding_hint(entry : WasmMountEntry) -> String {
  let config : @mars_adapters.WasmComponentConfig = {
    component: entry.id,
    world: "http-component",
    export_name: "handle",
  }
  let adapter = @mars_adapters.wasm_component_adapter(
    @mars.Server::new(),
    config~,
  )
  adapter.binding_hint()
}

///|
fn generate_wasm_entry_metadata_json(
  source : String,
  mount : WasmMountEntry,
) -> String {
  "{\n  \"id\": \"\{escape_json(mount.id)}\",\n  \"source\": \"\{escape_json(source)}\",\n  \"route\": \"\{escape_json(mount.route)}\",\n  \"method\": \{json_string_array(mount.methods)},\n  \"runtime\": \"\{wasm_entrypoint_runtime_to_string(mount.runtime)}\",\n  \"build\": \"\{wasm_build_kind_to_string(mount.build)}\",\n  \"wasm\": \"\{escape_json(mount.wasm)}\",\n  \"env\": \{json_string_map(mount.env)}\n}\n"
}

///|
fn json_string_array(values : Array[String]) -> String {
  let items = values.map(fn(v) { "\"\{escape_json(v)}\"" })
  let joined = items.join(", ")
  "[\{joined}]"
}

///|
fn json_string_map(values : Map[String, String]) -> String {
  if values.is_empty() {
    return "{}"
  }
  let items : Array[String] = []
  for item in values {
    items.push("\"\{escape_json(item.0)}\": \"\{escape_json(item.1)}\"")
  }
  let joined = items.join(", ")
  "{\{joined}}"
}

///|
fn toml_string_array(values : Array[String]) -> String {
  let items = values.map(fn(v) { "\"\{escape_toml(v)}\"" })
  let joined = items.join(", ")
  "[\{joined}]"
}

///|
fn escape_json(s : String) -> String {
  let out = StringBuilder::new()
  for c in s {
    if c == '"' {
      out.write_string("\\\"")
    } else if c == '\\' {
      out.write_string("\\\\")
    } else if c == '\n' {
      out.write_string("\\n")
    } else if c == '\r' {
      out.write_string("\\r")
    } else if c == '\t' {
      out.write_string("\\t")
    } else {
      out.write_char(c)
    }
  }
  out.to_string()
}

///|
fn escape_toml(s : String) -> String {
  let out = StringBuilder::new()
  for c in s {
    if c == '"' {
      out.write_string("\\\"")
    } else if c == '\\' {
      out.write_string("\\\\")
    } else {
      out.write_char(c)
    }
  }
  out.to_string()
}
