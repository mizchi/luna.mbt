// Sol CLI Templates - Embedded template files for project scaffolding
//

///|
fn template_gitignore() -> String {
  (
    #|.mooncakes
    #|_build
    #|target
    #|node_modules
    #|# Generated by sol generate (types/ is kept for initial build)
    #|app/__gen__/client
    #|app/__gen__/server
    #|.sol
  )
}

///|
fn template_moon_mod_json(package_name : String, luna_path : String?) -> String {
  match luna_path {
    Some(path) => {
      // Development mode - use local path
      let tmpl =
        #|{
        #|  "name": "{{PACKAGE_NAME}}",
        #|  "version": "0.1.0",
        #|  "deps": {
        #|    "mizchi/sol": "0.20.2",
        #|    "mizchi/mars": "0.3.10",
        #|    "mizchi/luna": {
        #|      "path": "{{LUNA_PATH}}"
        #|    },
        #|    "mizchi/signals": "0.6.4",
        #|    "mizchi/js": "0.10.15",
        #|    "mizchi/npm_typed": "0.1.11",
        #|    "moonbitlang/async": "0.17.0"
        #|  },
        #|  "source": "app",
        #|  "preferred-target": "js"
        #|}
      tmpl
      .replace(old="{{PACKAGE_NAME}}", new=package_name)
      .replace(old="{{LUNA_PATH}}", new=path)
    }
    None => {
      // Production mode - use mooncakes version
      let tmpl =
        #|{
        #|  "name": "{{PACKAGE_NAME}}",
        #|  "version": "0.1.0",
        #|  "deps": {
        #|    "mizchi/sol": "0.20.2",
        #|    "mizchi/mars": "0.3.10",
        #|    "mizchi/luna": "0.20.1",
        #|    "mizchi/signals": "0.6.4",
        #|    "mizchi/js": "0.10.15",
        #|    "mizchi/npm_typed": "0.1.11",
        #|    "moonbitlang/async": "0.17.0"
        #|  },
        #|  "source": "app",
        #|  "preferred-target": "js"
        #|}
      tmpl.replace(old="{{PACKAGE_NAME}}", new=package_name)
    }
  }
}

///|
fn template_package_json(project_name : String) -> String {
  let tmpl =
    #|{
    #|  "name": "{{PROJECT_NAME}}",
    #|  "version": "0.1.0",
    #|  "type": "module",
    #|  "scripts": {
    #|    "dev": "sol dev",
    #|    "build": "sol build",
    #|    "serve": "sol serve",
    #|    "generate": "sol generate"
    #|  },
    #|  "dependencies": {
    #|    "hono": "^4.12.12",
    #|    "@hono/node-server": "^1.19.13"
    #|  },
    #|  "devDependencies": {
    #|    "rolldown": "1.0.0-rc.13"
    #|  }
    #|}
  tmpl.replace(old="{{PROJECT_NAME}}", new=project_name)
}

///|
fn template_cloudflare_package_json(project_name : String) -> String {
  let tmpl =
    #|{
    #|  "name": "{{PROJECT_NAME}}",
    #|  "version": "0.1.0",
    #|  "type": "module",
    #|  "scripts": {
    #|    "dev": "sol build && wrangler dev",
    #|    "build": "sol build",
    #|    "deploy": "sol build && wrangler deploy",
    #|    "generate": "sol generate"
    #|  },
    #|  "dependencies": {
    #|    "hono": "^4.12.12"
    #|  },
    #|  "devDependencies": {
    #|    "rolldown": "1.0.0-rc.13",
    #|    "wrangler": "^4.81.0"
    #|  }
    #|}
  tmpl.replace(old="{{PROJECT_NAME}}", new=project_name)
}

///|
fn template_sol_config_json() -> String {
  (
    #|{
    #|  "islands": ["app/client"],
    #|  "routes": "app/server",
    #|  "output": "app/__gen__",
    #|  "runtime": "node"
    #|}
  )
}

///|
fn template_cloudflare_sol_config_json() -> String {
  (
    #|{
    #|  "islands": ["app/client"],
    #|  "routes": "app/server",
    #|  "output": "app/__gen__",
    #|  "runtime": "cloudflare"
    #|}
  )
}

// Note: For different runtimes, update sol.config.json:
// - "node"       - Node.js with @hono/node-server (default)
// - "cloudflare" - Cloudflare Workers (exports fetch handler)
// - "deno"       - Deno.serve
// - "bun"        - Bun.serve

// ============================================================================
// New Architecture Templates (routes-based)
// ============================================================================

///|
/// Layout template - provides basic HTML structure
/// Users explicitly call layout([...inner]) in their pages
pub fn template_layout_mbt() -> String {
  (
    #|///| Server Layout Component
    #|///|
    #|///| Provides the basic HTML structure for all pages.
    #|///| This is a server component - no event handlers.
    #|
    #|///| Default page styles
    #|let default_style : String = "<style>body { font-family: system-ui; max-width: 800px; margin: 0 auto; padding: 2rem; color: #1f2937; } nav { margin-bottom: 1rem; } nav a { margin-right: 1rem; } .muted { color: #6b7280; } .counter, .worker-panel { margin: 2rem 0; padding: 1rem; border: 1px solid #d1d5db; border-radius: 8px; } .panel-title { font-weight: 700; margin: 0 0 0.5rem; } .buttons, .format-options { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; } .buttons button, .format-options button { border: 1px solid #9ca3af; border-radius: 6px; background: #fff; padding: 0.5rem 0.85rem; cursor: pointer; } .counter .buttons button { font-size: 1.5rem; padding: 0.5rem 1rem; } .format-options .is-active { background: #111827; color: white; border-color: #111827; } .status { display: block; margin-top: 1rem; font-size: 0.9rem; color: #2563eb; }</style>"
    #|
    #|///| Get default head HTML (styles)
    #|pub fn head() -> String {
    #|  default_style
    #|}
    #|
    #|///| Basic layout wrapper - wraps content in container with navigation
    #|pub fn layout(inner : Array[@luna.Node[Unit, String]]) -> @luna.Node[Unit, String] {
    #|  div(class="container", [
    #|    nav([
    #|      a(href="/", [text("Home")]),
    #|      a(href="/about", [text("About")]),
    #|    ]),
    #|    outlet(name="main", inner),
    #|  ])
    #|}
    #|
    #|///| Root layout function for SolRoutes::Layout
    #|pub fn root_layout(
    #|  _props : @router.PageProps,
    #|  content : @server_dom.ServerNode,
    #|) -> @server_dom.ServerNode raise Error {
    #|  @server_dom.ServerNode::async_(async fn() {
    #|    let inner = content.resolve()
    #|    layout([inner])
    #|  })
    #|}
  )
}

