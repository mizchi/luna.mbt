    #|
    #|///| Router configuration
    #|pub fn config() -> @sol.RouterConfig {
    #|  @sol.RouterConfig::default()
    #|    .with_default_head(@layout.head())
    #|}
    #|
    #|// ============================================================================
    #|// Page Handlers
    #|// ============================================================================
    #|
    #|///| Home page - with counter island
    #|async fn home(_props : @sol.PageProps) -> @server_dom.ServerNode {
    #|  let counter_props : @types.CounterProps = { initial_count: 0 }
    #|  let api_tools_props : @types.ApiToolsProps = { endpoint: "/api/health" }
    #|  @sol.nodes([
    #|    h1([text("Welcome to Sol")]),
    #|    p([text("A SSR-first web framework for MoonBit operational apps")]),
    #|    @server_dom.client(@types.counter(counter_props), [
    #|      div(class="counter", [
    #|        span(class="count-display", [
    #|          text(counter_props.initial_count.to_string()),
    #|        ]),
    #|        div(class="buttons", [
    #|          button(class="dec", [text("-")]),
    #|          button(class="inc", [text("+")]),
    #|        ]),
    #|      ]),
    #|    ]),
    #|    @server_dom.client(@types.api_tools(api_tools_props), [
    #|      div(class="ops-panel", [
    #|        p(class="panel-title", [text("Operations Console")]),
    #|        p(class="muted", [text("Filter jobs, copy API links, and run guarded batch actions.")]),
    #|        div(class="buttons", [
    #|          button(class="copy-link", [text("Copy API URL")]),
