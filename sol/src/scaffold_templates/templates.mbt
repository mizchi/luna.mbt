// Sol scaffolding templates - shared between the JS `sol new` (in
// `mizchi/sol/cli`) and the native install shim (`mizchi/sol/cmd/sol`).
//
// IMPORTANT: keep this file pure (no FFI, no platform imports). The native
// `sol` binary depends on this package so that `sol new <name> --user <ns>`
// can scaffold a project from outside any moon project.

///|
/// Template file structure for generating project
pub(all) struct TemplateFile {
  path : String
  content : String
}

///|
pub fn template_gitignore() -> String {
  (
    #|.mooncakes
    #|_build
    #|target
    #|node_modules
    #|# Generated by sol generate (types/ is kept for initial build)
    #|app/__gen__/client
    #|app/__gen__/server
    #|.sol
  )
}

///|
pub fn template_moon_mod_json(
  package_name : String,
  luna_path : String?,
) -> String {
  match luna_path {
    Some(path) => {
      // Development mode - use local path
      let tmpl =
        #|{
        #|  "name": "{{PACKAGE_NAME}}",
        #|  "version": "0.1.0",
        #|  "deps": {
        #|    "mizchi/sol": "0.22.3",
        #|    "mizchi/sol_adapter_node": "0.22.3",
        #|    "mizchi/mars": "0.3.10",
        #|    "mizchi/luna": {
        #|      "path": "{{LUNA_PATH}}"
        #|    },
        #|    "mizchi/signals": "0.6.4",
        #|    "mizchi/js": "0.10.15",
        #|    "mizchi/npm_typed": "0.1.11",
        #|    "moonbitlang/async": "0.17.0"
        #|  },
        #|  "source": "app",
        #|  "preferred-target": "js"
        #|}
      tmpl
      .replace(old="{{PACKAGE_NAME}}", new=package_name)
      .replace(old="{{LUNA_PATH}}", new=path)
    }
    None => {
      // Production mode - use mooncakes version
      let tmpl =
        #|{
        #|  "name": "{{PACKAGE_NAME}}",
        #|  "version": "0.1.0",
        #|  "deps": {
        #|    "mizchi/sol": "0.22.3",
        #|    "mizchi/sol_adapter_node": "0.22.3",
        #|    "mizchi/mars": "0.3.10",
        #|    "mizchi/luna": "0.22.2",
        #|    "mizchi/signals": "0.6.4",
        #|    "mizchi/js": "0.10.15",
        #|    "mizchi/npm_typed": "0.1.11",
        #|    "moonbitlang/async": "0.17.0"
        #|  },
        #|  "source": "app",
        #|  "preferred-target": "js"
        #|}
      tmpl.replace(old="{{PACKAGE_NAME}}", new=package_name)
    }
  }
}

///|
pub fn template_package_json(project_name : String) -> String {
  let tmpl =
    #|{
    #|  "name": "{{PROJECT_NAME}}",
    #|  "version": "0.1.0",
    #|  "type": "module",
    #|  "scripts": {
    #|    "dev": "sol dev",
    #|    "build": "sol build",
    #|    "serve": "sol serve",
    #|    "generate": "sol generate"
    #|  },
    #|  "dependencies": {
    #|    "hono": "^4.12.12",
    #|    "@hono/node-server": "^1.19.13"
    #|  },
    #|  "devDependencies": {
    #|    "rolldown": "1.0.0-rc.13"
    #|  }
    #|}
  tmpl.replace(old="{{PROJECT_NAME}}", new=project_name)
}

///|
pub fn template_sol_config_json() -> String {
  (
    #|{
    #|  "islands": ["app/client"],
    #|  "routes": "app/server",
    #|  "output": "app/__gen__",
    #|  "runtime": "node"
    #|}
  )
}

///|
/// Layout template - provides basic HTML structure
/// Users explicitly call layout([...inner]) in their pages
pub fn template_layout_mbt() -> String {
  (
    #|///| Server Layout Component
    #|///|
    #|///| Provides the basic HTML structure for all pages.
    #|///| This is a server component - no event handlers.
    #|
    #|///| Default page metadata and styles
    #|let default_head : String = "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><meta name=\"description\" content=\"Sol operational app starter\"><link rel=\"icon\" href=\"/favicon.ico\"><style>body { font-family: system-ui; max-width: 1040px; margin: 0 auto; padding: 2rem; color: #1f2937; background: #f8fafc; } nav { margin-bottom: 1.25rem; } nav a { margin-right: 1rem; } h1 { margin-bottom: 0.25rem; } .muted { color: #6b7280; } .counter, .worker-panel, .ops-panel { margin: 1.5rem 0; padding: 1rem; border: 1px solid #d1d5db; border-radius: 8px; background: #fff; } .panel-title { display: block; font-weight: 700; margin: 0 0 0.5rem; } .buttons, .format-options, .filters, .pagination, .batch-actions, .state-strip { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; } button { border: 1px solid #9ca3af; border-radius: 6px; background: #fff; padding: 0.5rem 0.85rem; cursor: pointer; } .counter .buttons button { font-size: 1.5rem; padding: 0.5rem 1rem; } .is-active { background: #111827; color: white; border-color: #111827; } .status { display: block; margin-top: 1rem; font-size: 0.9rem; color: #2563eb; } .ops-table { display: grid; gap: 0.5rem; margin-top: 1rem; } .ops-row { display: grid; grid-template-columns: 7rem 1fr 6rem auto; gap: 0.75rem; align-items: center; padding: 0.65rem 0.75rem; border: 1px solid #e5e7eb; border-radius: 6px; } .ops-row.is-hidden { display: none; } .badge { display: inline-block; text-align: center; border-radius: 999px; padding: 0.2rem 0.55rem; background: #e0f2fe; color: #075985; font-size: 0.8rem; } .badge.pending { background: #fef3c7; color: #92400e; } .badge.failed { background: #fee2e2; color: #991b1b; } .badge.done, .badge.success { background: #dcfce7; color: #166534; } .batch-progress { margin-top: 0.75rem; height: 0.5rem; background: #e5e7eb; border-radius: 999px; overflow: hidden; } .batch-progress span { display: block; height: 100%; width: 40%; background: #2563eb; } .auth-note { margin-top: 0.75rem; font-size: 0.9rem; color: #4b5563; }</style>"
    #|
    #|///| Get default head HTML (metadata and styles)
    #|pub fn head() -> String {
    #|  default_head
    #|}
    #|
    #|///| Basic layout wrapper - wraps content in container with navigation
    #|pub fn layout(inner : Array[@luna.Node[Unit, String]]) -> @luna.Node[Unit, String] {
    #|  div(class="container", [
    #|    nav([
    #|      a(href="/", [text("Home")]),
    #|      a(href="/about", [text("About")]),
    #|    ]),
    #|    outlet(name="main", inner),
    #|  ])
    #|}
    #|
    #|///| Root layout function for SolRoutes::Layout
    #|pub fn root_layout(
    #|  _props : @router.PageProps,
    #|  content : @server_dom.ServerNode,
    #|) -> @server_dom.ServerNode raise Error {
    #|  @server_dom.ServerNode::async_(async fn() {
    #|    let inner = content.resolve()
    #|    layout([inner])
    #|  })
    #|}
  )
}

///|
/// Layout moon.pkg
pub fn template_layout_moon_pkg() -> String {
  (
    #|import {
    #|  "mizchi/luna" @luna,
    #|  "mizchi/sol/router" @router,
    #|  "mizchi/luna/dom/static" @server_dom,
    #|}
    #|
    #|supported_targets = "js"
    #|warnings = "-24"
  )
}

///|
/// Server alias.mbt template - DSL imports for server components
pub fn template_server_using_mbt() -> String {
  (
