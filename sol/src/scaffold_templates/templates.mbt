    #|        div(class="filters", [
    #|          button(class="is-active", [text("all")]),
    #|          button([text("pending")]),
    #|          button([text("failed")]),
    #|          button([text("done")]),
    #|        ]),
    #|        div(class="ops-table", [
    #|          div(class="ops-row", [
