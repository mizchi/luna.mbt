    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "axe-core": "^4.11.1",
    "colorette": "^2.0.20",
    "esbuild": "^0.27.3",
    "execa": "^9.6.1",
    "global-jsdom": "^28.0.0",
