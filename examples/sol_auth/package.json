{
  "name": "sol-auth-example",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync:assets": "node ../../scripts/sync-example-static-assets.mjs",
    "predev": "node ../../scripts/sync-example-static-assets.mjs",
    "dev": "node ../../_build/js/release/build/cli/cli.js dev",
    "dev:auth": "tsx dev-auth.ts",
    "dev:wrangler": "wrangler dev",
    "prebuild": "node ../../scripts/sync-example-static-assets.mjs",
    "build": "node ../../_build/js/release/build/cli/cli.js build",
    "preserve": "node ../../scripts/sync-example-static-assets.mjs",
    "serve": "node ../../_build/js/release/build/cli/cli.js serve",
    "pretest": "node ../../scripts/sync-example-static-assets.mjs",
    "test": "playwright test",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create sol-auth-db",
    "db:migrate": "wrangler d1 execute sol-auth-db --file=migrations/0001_init.sql",
    "db:migrate:local": "wrangler d1 execute sol-auth-db --local --file=migrations/0001_init.sql"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "better-auth": "^1.4.18",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260218.0",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.21.0",
    "wrangler": "^4.66.0"
  }
}
